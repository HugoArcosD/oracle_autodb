*.tfvars
*.tfvars.json

# Ignore override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Wallet directory (contains SSL certificates and private keys)
Wallet_POCDB/
wallet/
*wallet*/

# OCI API key files
*.pem
*.key
*.pub

# Virtual environment
venv/
venv-*/
.venv

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Python
__pycache__/
*.pyc
*.egg-info/
dist/
build/

# OS
*.log
.env
